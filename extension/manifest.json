{
  "manifest_version": 3,
  "name": "GMap Review Decoder (문화권 맞춤 리뷰 분석)",
  "version": "1.0.0",
  "description": "구글 맵스 장소의 리뷰를 한국인 등 선호 문화권 관점으로 보정하고 뉘앙스를 해독해주는 우측 오버레이 익스텐션",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://www.google.co.kr/maps/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GMap Review Decoder 설정"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://www.google.co.kr/maps/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles.css", "data/sample_places.json"],
      "matches": [
        "https://www.google.com/*",
        "https://www.google.co.kr/*"
      ]
    }
  ]
}
